{
  "name": "wren",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/fredoka": "~0.2.3",
    "@expo-google-fonts/inter": "~0.2.3",
    "@expo/ui": "~56.0.18",
    "@gorhom/bottom-sheet": "5.1.5",
    "@react-native/jest-preset": "^0.86.0",
    "@shopify/flash-list": "1.7.3",
    "drizzle-orm": "0.41.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.5",
    "expo-linking": "~56.0.14",
    "expo-media-library": "~56.0.5",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.3",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "0.30.6",
    "eslint": "^9.0.0",
    "eslint-config-expo": "^9.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/__mocks__/react-native-get-random-values/index.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|@gorhom/.*|drizzle-orm|uuid)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
